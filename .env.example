# EduCore — Variables de Entorno
# Copia este archivo como .env y rellena los valores

# ──────────────────────────────
# SERVIDOR
# ──────────────────────────────
PORT=8080
APP_ENV=development
ENVIRONMENT=development
APP_NAME=EduCore

# ──────────────────────────────
# BASE DE DATOS
# ──────────────────────────────
DB_DRIVER=postgres
DATABASE_URL=postgres://educore:educore_dev_password@localhost:5432/educore_dev?sslmode=disable
# Puente temporal Hostinger MySQL/phpMyAdmin. Usar solo con Remote MySQL por IP allowlist.
# Formato: user:password@tcp(host:3306)/database?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci
MYSQL_DSN=
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5
ALLOW_DEMO_LOGIN=false

# Frontend static export. En produccion debe ser false para no incluir logins demo.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_DEMO_PASSWORD=

# ──────────────────────────────
# REDIS
# ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────
# JWT
# ──────────────────────────────
JWT_SECRET=tu-secret-aqui-cambialo-en-produccion-minimo-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ──────────────────────────────
# CORS
# ──────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────
# EMAIL (Resend)
# ──────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@educore.mx
EMAIL_FROM_NAME=EduCore

# ──────────────────────────────
# STORAGE (local en dev, S3 en prod)
# ──────────────────────────────
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# Para producción:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=xxxx
# AWS_SECRET_ACCESS_KEY=xxxx
# AWS_REGION=us-east-1
# AWS_BUCKET=educore-prod

# ──────────────────────────────
# OBSIDIAN SYNC (opcional)
# ──────────────────────────────
# OBSIDIAN_VAULT_PATH=/Users/tu_usuario/Documents/Obsidian/EduCore

# ──────────────────────────────
# SUPER ADMIN (se crea en seed)
# ──────────────────────────────
SUPER_ADMIN_EMAIL=admin@educore.mx
SUPER_ADMIN_PASSWORD=cambiar_en_produccion
EDUCORE_DEFAULT_SCHOOL_ADMIN_PASSWORD=cambiar_esta_password_segura
EDUCORE_OWNER_ADMIN_EMAILS=gioescudero2007@gmail.com,jagustin_ramosp@hotmail.com
EDUCORE_OWNER_ADMIN_PASSWORD=
